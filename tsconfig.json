        "./Cache/TypeScript/Src/Assets/Scripts/Touch Events_5.11.lsc/*"
      ]
    },
    "skipDefaultLibCheck": true,
    "target": "es2021",
    "types": []
  },
  "exclude": [
    "node_modules/typescript/lib/lib.dom.d.ts"
  ],
  "include": [
    "./Cache/TypeScript/lib/LensifyTS/Declarations/**/*.d.ts",
    "./Assets/**/*.ts",
    "./Packages/**/*.ts",
    "./Cache/TypeScript/Src/Packages/**/*.ts",
    "./Cache/TypeScript/Src/Assets/Scripts/Hand_Tracking.lsc/**/*.ts",
    "./Cache/TypeScript/Src/Assets/Scripts/Touch Events_5.11.lsc/**/*.ts",
    "./Cache/TypeScript/Src/Assets/Scripts/Screen Text_5.12.lsc/**/*.ts",
    "./Cache/TypeScript/Src/Assets/Scripts/CanvasAPI_5.14.lsc/**/*.ts",
    "./Cache/TypeScript/Src/Assets/Scripts/SpriteManager_5.14.lsc/**/*.ts"
